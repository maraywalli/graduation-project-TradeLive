# =============================================================================
# TradeLive Pro — Environment Variables
# Copy this file to .env.local for local dev, or set the same keys in your
# Vercel project settings (Production + Preview) for deployment.
# =============================================================================

# --- Supabase (Auth + Postgres + Storage + Realtime) -------------------------
# From: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Pooled connection string (used by scripts/setup-db.ts only):
SUPABASE_DB_URL=

# --- Stripe payment gateway --------------------------------------------------
# From: https://dashboard.stripe.com/apikeys
# Use sk_test_ / pk_test_ for development, sk_live_ / pk_live_ for production.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe webhook signing secret (whsec_...).
# Create the endpoint in your Stripe Dashboard → Developers → Webhooks →
# Add endpoint with URL https://<your-domain>/api/webhooks/stripe and these
# events:
#   - checkout.session.completed
#   - checkout.session.async_payment_succeeded
#   - checkout.session.async_payment_failed
#   - checkout.session.expired
# Copy the "Signing secret" into this variable. Without it the webhook route
# returns 503 and Stripe will retry — return-page confirmation still works.
STRIPE_WEBHOOK_SECRET=

# Stripe doesn't support IQD. Item prices are stored & displayed in IQD but
# the actual charge is made in USD using this conversion rate (default 1310).
IQD_PER_USD=1310

# Optional — overrides the auto-detected origin used to build the success /
# cancel return URLs that Stripe redirects the buyer back to.
NEXT_PUBLIC_APP_URL=

# --- OpenAI (AI product description writer + admin reports) ------------------
OPENAI_API_KEY=

# --- Hugging Face (optional fallback for AI image generation) ----------------
HF_TOKEN=

# --- ZainCash (Iraq mobile wallet — optional) --------------------------------
ZAINCASH_ENV=test
ZAINCASH_MERCHANT_ID=
ZAINCASH_MSISDN=
ZAINCASH_SECRET=

# --- App URL (for absolute links in emails, callbacks) -----------------------
# Vercel sets VERCEL_URL automatically; leave blank in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:5000
